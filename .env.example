# --- Slack (bot token via the relay's slack_post tool — NOT MCP; the MCP/vault path is parked) ---
# SLACK_BOT_TOKEN (xoxb-, scope chat:write, bot invited to the channel) + SLACK_CHANNEL_ID are required.
# SLACK_SIGNING_SECRET secures the link-trigger (/api/slack/events) + Accept button (/api/slack/interactivity).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=
# Parked (Slack-MCP-over-vault path — no OAuth token to mint; not used):
SLACK_MCP_URL=
SLACK_VAULT_ID=

# --- App ---
PUBLIC_BASE_URL=http://localhost:3000
